# Copy to .env and fill in. Never commit .env.

# Claude reconciliation call (Spec 2 §2.5)
ANTHROPIC_API_KEY=

# OCR (A2-1: Google Cloud Vision)
# Path to a service-account JSON key file, or set GOOGLE_APPLICATION_CREDENTIALS instead.
GOOGLE_APPLICATION_CREDENTIALS=

# ASR (A2-2: OpenAI Whisper API)
OPENAI_API_KEY=

# Symmetric key used to encrypt the local H-E-B storage-state file at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HEB_SESSION_KEY=

# Local data directory (SQLite db, per-job temp media, encrypted session file)
DATA_DIR=./data
