# Copy to .env and fill in. Never commit .env.

# Claude reconciliation call (Spec 2 §2.5) — the ONLY cloud AI dependency by
# design. OCR (tesseract.js) and ASR (local Whisper via
# @huggingface/transformers) both run entirely on-device — no key needed.
ANTHROPIC_API_KEY=

# Kroger Public API (Spec 3 §2.1) — register a free app at developer.kroger.com
# (self-service, no approval process) to get these.
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
# Must exactly match the redirect URI registered on the Kroger app. Default
# matches the local CLI callback server used by `recipecart auth` in P1.
KROGER_REDIRECT_URI=http://localhost:3000/callback

# Symmetric key used to encrypt the local Kroger OAuth token pair (access +
# refresh token) at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KROGER_TOKEN_KEY=

# Local data directory (per-job temp media, encrypted Kroger token file)
DATA_DIR=./data

# Postgres (Spec 4 §2.2 / Phase 3). CLI, web, and worker all point at the same
# DB. The default below matches the docker-compose `postgres` service; a native
# local install would use e.g. postgresql://<user>@localhost:5432/recipecart.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recipecart
# Separate database for the test suite (never point this at your dev DB — the
# tests TRUNCATE all tables between cases).
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recipecart_test
