# Copy to .env and fill in. Never commit .env.

# Claude reconciliation call (Spec 2 §2.5) — the ONLY cloud AI dependency by
# design. OCR (tesseract.js) and ASR (local Whisper via
# @huggingface/transformers) both run entirely on-device — no key needed.
ANTHROPIC_API_KEY=

# Kroger Public API (Spec 3 §2.1) — register a free app at developer.kroger.com
# (self-service, no approval process) to get these.
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
# Must exactly match the redirect URI registered on the Kroger developer
# dashboard. The web API's callback route is canonical since Phase 3 (the
# old P1 CLI-only callback server at :3000/callback is retired); in
# production this must point at the deployed API's callback URL instead —
# see docs/deploy-railway.md.
KROGER_REDIRECT_URI=http://localhost:3001/api/kroger/auth/callback

# Symmetric key used to encrypt the local Kroger OAuth token pair (access +
# refresh token) at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KROGER_TOKEN_KEY=

# Google OAuth2/OIDC (multi-tenancy Slice 1) — the sign-in mechanism, not an
# AI dependency (see config.ts's comment on this). Create an OAuth 2.0
# Client ID (Web application type) at console.cloud.google.com under "APIs &
# Services > Credentials"; enable the OpenID Connect consent scopes
# (openid, email, profile — the defaults). No approval process for these
# scopes at low usage.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match a redirect URI registered on the Google Cloud Console
# OAuth client (same reasoning as KROGER_REDIRECT_URI above); in production
# this must point at the deployed API's callback URL — see
# docs/deploy-railway.md.
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Signup is open (no allowlist, 2026-07-22 — homebrew project, explicit
# user call) — any verified Google account can create a RecipeCart account.
# This one email is the exception: it's the account allowed to CLAIM the
# pre-existing single-tenant account and all its existing recipes/
# preferences on its first login, instead of starting a brand-new empty
# account like everyone else. Set it to your own email.
OWNER_EMAIL=

# Local data directory (per-job temp media, encrypted Kroger token file)
DATA_DIR=./data

# Postgres (Spec 4 §2.2 / Phase 3). CLI, web, and worker all point at the same
# DB. The default below matches the docker-compose `postgres` service; a native
# local install would use e.g. postgresql://<user>@localhost:5432/recipecart.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recipecart
# Separate database for the test suite (never point this at your dev DB — the
# tests TRUNCATE all tables between cases).
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recipecart_test
# Set to any non-empty value (e.g. "require") when DATABASE_URL points at a
# managed Postgres (Railway, etc.) that requires TLS. Leave unset for local
# Docker Compose / native Postgres. See src/platform/database.ts.
PGSSL=

# Origin the web app is served from — the Kroger OAuth callback redirects
# here after a successful token exchange (src/api/routes/kroger_auth.ts).
# Must be an ABSOLUTE origin: a relative redirect resolves against the API
# server's own origin, which is wrong whenever web and API are on different
# origins. Local dev is genuinely split (Vite on :5173, API on :3001,
# because `web` isn't built there — see server.ts). In production (Phase 4)
# the api process serves the built web/dist itself (one Railway service),
# so WEB_APP_URL there equals the api's own production URL, not a separate
# domain — see docs/deploy-railway.md.
WEB_APP_URL=http://localhost:5173

# API listen port. Railway injects PORT automatically and expects the
# process to bind it — set this only for local overrides. Falls back to
# API_PORT (legacy local-dev name), then 3001, if unset.
PORT=3001
