# Copy to .env and fill in. Never commit .env.

# Claude reconciliation call (Spec 2 §2.5)
ANTHROPIC_API_KEY=

# OCR (A2-1: Google Cloud Vision)
# Path to a service-account JSON key file, or set GOOGLE_APPLICATION_CREDENTIALS instead.
GOOGLE_APPLICATION_CREDENTIALS=

# ASR (A2-2: OpenAI Whisper API)
OPENAI_API_KEY=

# Kroger Public API (Spec 3 §2.1) — register a free app at developer.kroger.com
# (self-service, no approval process) to get these.
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# Symmetric key used to encrypt the local Kroger OAuth token pair (access +
# refresh token) at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KROGER_TOKEN_KEY=

# Local data directory (SQLite db, per-job temp media, encrypted token file)
DATA_DIR=./data
