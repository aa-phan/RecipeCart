{
  "name": "recipecart",
  "version": "0.1.0",
  "private": true,
  "description": "TikTok Recipe -> Kroger Cart Automation (RecipeCart) — Phase 0/1 barebones local pipeline",
  "type": "module",
  "bin": {
    "recipecart": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/cli.ts",
    "worker": "tsx src/worker/index.ts",
    "api": "tsx src/api/index.ts",
    "start:api": "exec node dist/api/index.js",
    "start:worker": "exec node dist/worker/index.js",
    "migrate": "tsx src/platform/migrate.ts",
    "start:migrate": "node dist/platform/migrate.js",
    "spike:tiktok": "tsx spikes/tiktok-media-spike.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^10.1.0",
    "@huggingface/transformers": "^4.2.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "kysely": "^0.29.4",
    "pg": "^8.22.0",
    "tesseract.js": "^7.0.0",
    "zod": "^3.23.8"
  },
  "overrides": {
    "adm-zip": "^0.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.7.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  }
}
